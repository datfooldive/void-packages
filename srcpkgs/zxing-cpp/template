# Template file for 'zxing-cpp'
pkgname=zxing-cpp
version=3.1.0
revision=1
build_style=cmake
configure_args="-DZXING_BLACKBOX_TESTS=OFF -DZXING_DEPENDENCIES=LOCAL
 -DZXING_WRITERS=BOTH"
hostmakedepends="pkg-config"
makedepends="stb"
checkdepends="gtest-devel"
short_desc="Multi-format 1D/2D barcode image processing library"
maintainer="John <me@johnnynator.dev>"
license="Apache-2.0"
homepage="https://github.com/zxing-cpp/zxing-cpp/"
changelog="https://github.com/zxing-cpp/zxing-cpp/releases"
distfiles="https://github.com/zxing-cpp/zxing-cpp/archive/refs/tags/v${version}.tar.gz"
distfiles="https://github.com/zxing-cpp/zxing-cpp/releases/download/v${version}/zxing-cpp-${version}.tar.gz"
checksum=a3eb825154f05242283e7d94d8ebdcf95beb3a534eba393cce504e91c9b215bd

if [ "$XBPS_CHECK_PKGS" ]; then
	configure_args+=" -DZXING_UNIT_TESTS=ON"
else
	configure_args+=" -DZXING_UNIT_TESTS=OFF"
fi

zxing-cpp-devel_package() {
	depends="${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.so"
	}
}

zxing-cpp-progs_package() {
	short_desc+=" - programs"
	pkg_install() {
		vmove usr/bin
	}
}
