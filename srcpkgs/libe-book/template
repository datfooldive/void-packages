# Template file for 'libe-book'
pkgname=libe-book
version=0.1.4
revision=1
build_style=gnu-configure
configure_args="--disable-werror"
hostmakedepends="automake libtool gperf doxygen pkg-config"
makedepends="boost-headers icu-devel libcppunit-devel libxml2-devel
 librevenge-devel liblangtag-devel zlib-devel"
short_desc="Import reflowable e-book formats"
maintainer="Đoàn Trần Công Danh <congdanhqx@gmail.com>"
license="MPL-2.0"
homepage="http://sourceforge.net/projects/libebook/"
distfiles="${SOURCEFORGE_SITE}/project/libebook/${pkgname}-${version}/${pkgname}-${version}.tar.xz"
checksum=104b7e791b6632745898e9b6a0037b7540235771a4d8c3bde2c764466ad912f1

pre_configure() {
	autoreconf -fi
}

libe-book-devel_package() {
	short_desc+=" - development files"
	depends="${sourcepkg}>=${version}_${revision} librevenge-devel icu-devel
	 libxml2-devel liblangtag-devel zlib-devel"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove usr/lib/*.so
	}
}

libe-book-doc_package() {
	short_desc+=" - documentation"
	depends="${sourcepkg}>=${version}_${revision}"
	pkg_install() {
		vmove usr/share/doc
	}
}
