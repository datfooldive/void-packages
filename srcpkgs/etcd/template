# Template file for 'etcd'
pkgname=etcd
version=3.7.1
revision=1
build_style=go
go_import_path="go.etcd.io/etcd/v3"
go_package="
 go.etcd.io/etcd/server/v3
 go.etcd.io/etcd/etcdctl/v3
 go.etcd.io/etcd/etcdutl/v3
"
short_desc="Distributed reliable key-value store"
