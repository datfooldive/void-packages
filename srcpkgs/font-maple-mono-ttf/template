# Template file for 'font-maple-mono-ttf'
pkgname=font-maple-mono-ttf
version=7.9
revision=1
depends="font-util"
short_desc="Open source monospace font with round corner and ligatures"
maintainer="datfooldive <datfooldive@gmail.com>"
license="OFL-1.1"
homepage="https://github.com/subframe7536/Maple-font"
distfiles="https://github.com/subframe7536/Maple-font/releases/download/v${version}/MapleMono-TTF.zip"
checksum=3a35f8f0669bef3dded9df208cc4526a6f7573210e134816e9084a8981271d75
font_dirs="/usr/share/fonts/TTF"
provides="font:monospace-0_1"

do_install() {
	vmkdir usr/share/fonts/TTF
	for f in "${wrksrc}"/*.ttf; do
		vinstall "$f" 644 usr/share/fonts/TTF
	done
	vlicense LICENSE.txt
}
